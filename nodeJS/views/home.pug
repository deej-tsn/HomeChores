extends layout 

block title 
    title #{title}

block header
    h1 #{title}

block content
    div.container
        div.row
            div.col.text-center
                h1 Hi #{name}
        .row
            .col.text-center
                a.btn(href="/add_person_chore") Add Chore
                a.btn(href="/viewChoresDone") View Chores Done
                a.btn(href="/viewPointsEarned") View Points Earned
                a.btn(href="/viewChoreInfo") Chores Info 
        .row
            .col.text-center
                form.btn.form-registration(action="/logout?_method=DELETE" method="POST")
                    button.btn.btn-lg.btn-primary.btn-block(type="submit") Log Out
                

